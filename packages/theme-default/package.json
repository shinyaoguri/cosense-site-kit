{
  "name": "@cosense-site-kit/theme-default",
  "version": "0.6.0",
  "description": "Default theme for cosense-site-kit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shinyaoguri/cosense-site-kit.git",
    "directory": "packages/theme-default"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": "./src/components/*",
    "./templates/*": "./src/templates/*",
    "./styles/*": "./src/styles/*"
  },
  "files": [
    "dist",
    "src",
    "!dist/.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "astro": "^5.0.0 || ^6.0.0"
  },
  "dependencies": {
    "@cosense-site-kit/core": "^0.3.0",
    "@cosense-site-kit/theme-utils": "^0.3.0",
    "pagefind": "^1.5.2"
  },
  "devDependencies": {
    "astro": "^6.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
