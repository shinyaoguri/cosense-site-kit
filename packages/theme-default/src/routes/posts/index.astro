---
import { getCollection } from "astro:content";
import options from "virtual:cosense-theme-default/options";
import Layout from "../../components/Layout.astro";
import { loadStructure, path } from "../../lib/structure";

const structure = await loadStructure();

// /posts is only meaningful when the .site page declares a posts tag.
// If it isn't configured, return a stub page so the route doesn't crash.
const postTag = structure.posts?.tag;

const all = await getCollection(options.collection as "pages");
const posts = postTag
  ? all
      .filter((e) => e.data.tags.includes(postTag))
      .sort((a, b) => (b.data.updatedAt ?? "").localeCompare(a.data.updatedAt ?? ""))
  : [];
---
<Layout title="Posts">
  {postTag ? (
    <>
      <h1>Posts</h1>
      <ul class="recent-pages">
        {posts.map((entry) => (
          <li>
            <a href={path(entry.data.slug)}>{entry.data.title}</a>
            {entry.data.summary && <p class="summary">{entry.data.summary}</p>}
            {entry.data.updatedAt && (
              <time class="updated" datetime={entry.data.updatedAt}>
                {new Date(entry.data.updatedAt).toISOString().slice(0, 10)}
              </time>
            )}
          </li>
        ))}
      </ul>
    </>
  ) : (
    <>
      <h1>Posts</h1>
      <p>Posts are not configured for this site.</p>
    </>
  )}
</Layout>
