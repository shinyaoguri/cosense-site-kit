---
import { isPublicTag, path } from "@cosense-site-kit/theme-utils";

// Public tags for a list card. Every tag is rendered on a single (clipped) line;
// the inline script below measures how many fit the card's current width, hides
// the overflow, and labels a "+N" badge with the remainder — recomputing on
// resize. With no JS the row just clips to one line (no badge), so the card keeps
// its height either way. The number shown therefore adapts to the card width
// instead of a fixed count. Renders nothing when there are no public tags.
interface Props {
  /** The page's full tag list; control/metadata tags are filtered out. */
  tags: string[];
}

const { tags } = Astro.props;
const publicTags = tags.filter(isPublicTag);
---
{publicTags.length > 0 && (
  <span class="entry-tags" data-entry-tags>
    {publicTags.map((tag) => (
      <a class="tag" href={path(`tags/${tag}`)}>#{tag}</a>
    ))}
    <span class="tag more-tags" style="display:none" aria-hidden="true">+0</span>
  </span>
)}

<script>
  // Collapse the tags that overflow a card's width into a "+N" badge. Positions
  // are read with getBoundingClientRect so the math is independent of offset
  // parents and of the container's `overflow: hidden` clipping.
  function fit(container: HTMLElement) {
    const badge = container.querySelector<HTMLElement>(".more-tags");
    if (!badge) return;
    const chips = Array.from(container.querySelectorAll<HTMLElement>(".tag")).filter(
      (chip) => chip !== badge,
    );
    const last = chips.at(-1);
    if (!last) return;

    // Reset to the "everything visible, no badge" state before measuring.
    for (const chip of chips) chip.style.display = "";
    badge.style.display = "none";

    const right = container.getBoundingClientRect().right;
    if (last.getBoundingClientRect().right <= right + 0.5) return; // all fit on one line

    // Overflow: reveal the badge, reserve its width, then keep the chips that
    // still fit before it. Measuring with the widest possible count avoids the
    // badge growing past its reserved slot once the real number is shorter.
    badge.style.display = "";
    badge.textContent = `+${chips.length}`;
    const gap = Number.parseFloat(getComputedStyle(container).columnGap) || 0;
    const limit = right - badge.getBoundingClientRect().width - gap;

    let shown = 0;
    for (const chip of chips) {
      if (chip.getBoundingClientRect().right <= limit + 0.5) shown++;
      else break;
    }
    if (shown < 1) shown = 1; // always keep at least one tag visible
    chips.forEach((chip, i) => {
      chip.style.display = i < shown ? "" : "none";
    });
    badge.textContent = `+${chips.length - shown}`;
  }

  function fitAll() {
    for (const el of document.querySelectorAll<HTMLElement>("[data-entry-tags]")) fit(el);
  }

  let raf = 0;
  function schedule() {
    cancelAnimationFrame(raf);
    raf = requestAnimationFrame(fitAll);
  }

  fitAll();
  window.addEventListener("resize", schedule);
  // Web fonts change chip widths once swapped in; re-measure when they're ready.
  document.fonts?.ready.then(fitAll);
</script>
