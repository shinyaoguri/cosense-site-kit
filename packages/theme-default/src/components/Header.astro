---
import site from "virtual:cosense-site-kit/site";
import options from "virtual:cosense-theme-default/options";
import { loadStructure, loadTitleToSlug, navHref } from "@cosense-site-kit/theme-utils";
import Search from "./Search.astro";

interface Props {
  currentPath?: string;
}
const { currentPath = "/" } = Astro.props;

const siteTitle =
  options.siteTitle ?? site?.title ?? (Astro.site ? new URL("/", Astro.site).hostname : "Site");

const structure = await loadStructure();
const navItems = structure.nav.length > 0 ? structure.nav : options.nav;
const titleToSlug = await loadTitleToSlug();
const hasMenu = navItems.length > 0 || options.search;

const isActive = (href: string): boolean => {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---
<header class="site-header">
  <div class="site-header-inner">
    <a class="site-brand" href={import.meta.env.BASE_URL}>{siteTitle}</a>
    {hasMenu && (
      <Fragment>
        <button
          type="button"
          class="site-nav-toggle"
          aria-label="Toggle menu"
          aria-controls="site-menu"
          aria-expanded="false"
        >
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
        <div class="site-menu" id="site-menu">
          {options.search && <Search />}
          {navItems.length > 0 && (
            <ul class="site-nav">
              {navItems.map((item) => {
                const href = navHref(item, titleToSlug);
                return (
                  <li>
                    <a href={href} class:list={[{ "is-active": isActive(href) }]}>
                      {item.label}
                    </a>
                  </li>
                );
              })}
            </ul>
          )}
        </div>
      </Fragment>
    )}
  </div>
</header>

<script>
  // Progressive enhancement: without JS the menu wraps under the brand and
  // stays visible (CSS). With JS we collapse it behind the hamburger on narrow
  // screens. `has-js` gates the collapsed CSS so no-JS users keep a usable menu.
  const header = document.querySelector<HTMLElement>(".site-header");
  const toggle = header?.querySelector<HTMLButtonElement>(".site-nav-toggle");
  const menu = header?.querySelector<HTMLElement>(".site-menu");
  if (header && toggle && menu) {
    header.classList.add("has-js");
    const setOpen = (open: boolean) => {
      menu.classList.toggle("is-open", open);
      toggle.setAttribute("aria-expanded", String(open));
    };
    toggle.addEventListener("click", () => setOpen(!menu.classList.contains("is-open")));
    // Close after following a link, on Escape, or when clicking outside.
    menu.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) setOpen(false);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") setOpen(false);
    });
    document.addEventListener("click", (e) => {
      if (!header.contains(e.target as Node)) setOpen(false);
    });
  }
</script>
