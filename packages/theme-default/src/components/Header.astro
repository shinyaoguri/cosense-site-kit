---
import site from "virtual:cosense-site-kit/site";
import options from "virtual:cosense-theme-default/options";
import { loadStructure, loadTitleToSlug, navHref } from "@cosense-site-kit/theme-utils";
import Search from "./Search.astro";

interface Props {
  currentPath?: string;
}
const { currentPath = "/" } = Astro.props;

const siteTitle =
  options.siteTitle ?? site?.title ?? (Astro.site ? new URL("/", Astro.site).hostname : "Site");

const structure = await loadStructure();
const navItems = structure.nav.length > 0 ? structure.nav : options.nav;
const titleToSlug = await loadTitleToSlug();

const isActive = (href: string): boolean => {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---
<header class="site-header">
  <div class="site-header-inner">
    <a class="site-brand" href={import.meta.env.BASE_URL}>{siteTitle}</a>

    {options.search && <Search />}

    {navItems.length > 0 && (
      <Fragment>
        <button
          type="button"
          class="site-nav-toggle"
          aria-label="Toggle navigation"
          aria-controls="site-nav-wrap"
          aria-expanded="false"
        >
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
        <nav class="site-nav-wrap" id="site-nav-wrap" aria-label="Primary">
          <ul class="site-nav">
            {navItems.map((item) => {
              const href = navHref(item, titleToSlug);
              return (
                <li>
                  <a href={href} class:list={[{ "is-active": isActive(href) }]}>
                    {item.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      </Fragment>
    )}
  </div>
</header>

<script>
  // Header behaviour, progressively enhanced. `has-js` gates the collapsed
  // layouts so without JS the nav stays visible (wrapped) and the search icon
  // is hidden (search needs JS + a built index anyway).
  const header = document.querySelector<HTMLElement>(".site-header");
  if (header) {
    header.classList.add("has-js");

    const navToggle = header.querySelector<HTMLButtonElement>(".site-nav-toggle");
    const navWrap = header.querySelector<HTMLElement>(".site-nav-wrap");
    const searchRoot = header.querySelector<HTMLElement>(".site-search");
    const searchToggle = header.querySelector<HTMLButtonElement>(".site-search-toggle");
    const searchPanel = header.querySelector<HTMLElement>("#site-search-panel");
    const searchNote = searchPanel?.querySelector<HTMLElement>(".site-search-note") ?? null;
    const bundlePath = searchRoot?.dataset.bundlePath ?? "/pagefind/";

    const focusSearchInput = () =>
      requestAnimationFrame(() => searchPanel?.querySelector("input")?.focus());

    const setNav = (open: boolean) => {
      navWrap?.classList.toggle("is-open", open);
      navToggle?.setAttribute("aria-expanded", String(open));
    };
    const setSearch = (open: boolean) => {
      if (!searchPanel) return;
      searchPanel.hidden = !open;
      searchToggle?.setAttribute("aria-expanded", String(open));
      if (open) {
        loadSearch();
        focusSearchInput();
      }
    };

    // Lazy-load the Pagefind UI the first time search is opened. If the bundle
    // isn't there (e.g. `astro dev` before a build), show the note instead.
    let searchRequested = false;
    const loadSearch = () => {
      if (searchRequested) return;
      searchRequested = true;
      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = `${bundlePath}pagefind-ui.css`;
      document.head.appendChild(link);
      const script = document.createElement("script");
      script.src = `${bundlePath}pagefind-ui.js`;
      script.addEventListener("load", () => {
        const Ctor = (window as unknown as { PagefindUI?: new (o: unknown) => unknown }).PagefindUI;
        if (typeof Ctor === "function") {
          new Ctor({
            element: "#cosense-search",
            bundlePath,
            showImages: false,
            showSubResults: true,
            translations: { placeholder: "Search" },
          });
          focusSearchInput();
        } else if (searchNote) {
          searchNote.hidden = false;
        }
      });
      script.addEventListener("error", () => {
        if (searchNote) searchNote.hidden = false;
      });
      document.head.appendChild(script);
    };

    navToggle?.addEventListener("click", () => {
      const open = !navWrap?.classList.contains("is-open");
      setNav(open);
      if (open) setSearch(false);
    });
    searchToggle?.addEventListener("click", () => {
      const open = Boolean(searchPanel?.hidden);
      setSearch(open);
      if (open) setNav(false);
    });
    navWrap?.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) setNav(false);
    });
    const isTyping = (el: EventTarget | null) => {
      const node = el as HTMLElement | null;
      const tag = node?.tagName;
      return tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT" || !!node?.isContentEditable;
    };
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        setNav(false);
        setSearch(false);
        return;
      }
      // GitHub-style "/" shortcut: focus search unless already typing in a field.
      if (e.key === "/" && searchPanel && !isTyping(e.target)) {
        e.preventDefault();
        setNav(false);
        setSearch(true);
      }
    });
    document.addEventListener("click", (e) => {
      if (!header.contains(e.target as Node)) {
        setNav(false);
        setSearch(false);
      }
    });
  }
</script>
