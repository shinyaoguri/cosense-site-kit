---
import options from "virtual:cosense-theme-default/options";
import site from "virtual:cosense-site-kit/site";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import TableOfContents from "./TableOfContents.astro";
import CodeBlockEnhancer from "./CodeBlockEnhancer.astro";
import KaTeXLink from "@cosense-site-kit/theme-utils/components/KaTeXLink.astro";
import { loadStructure } from "@cosense-site-kit/theme-utils";
import { resolveActiveSkin } from "../presets";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  /** Hide the floating right-side TOC (use on home / archive / tag pages). */
  hideToc?: boolean;
}

const { title, description, hideToc = false } = Astro.props;

const siteTitle =
  options.siteTitle ??
  site?.title ??
  (Astro.site ? new URL("/", Astro.site).hostname : title);
const fullTitle = siteTitle && siteTitle !== title ? `${title} | ${siteTitle}` : title;
const metaDescription = description ?? site?.description ?? "";
const lang = site?.lang ?? "ja";

// Preset (skin) support. The active skin comes from `.site` YAML `theme.skin`
// (operator-controlled, switchable in Cosense with no repo edit) and falls back
// to the preset wired in astro.config.ts. Token overrides go on the <html>
// inline style so they beat the :root defaults in global.css regardless of
// stylesheet order; fonts are preset-driven (they load via a <link>).
const structure = await loadStructure();
const { tokens, colorScheme, fontHref } = resolveActiveSkin(structure.theme?.skin, options);
const htmlStyle = [
  colorScheme ? `color-scheme:${colorScheme}` : null,
  ...Object.entries(tokens).map(([k, v]) => `${k}:${v}`),
]
  .filter(Boolean)
  .join(";");
---
<!doctype html>
<html lang={lang} data-theme={colorScheme ?? undefined} style={htmlStyle || undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    {metaDescription && <meta name="description" content={metaDescription} />}
    {site?.icon && <link rel="icon" href={site.icon} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {fontHref ? (
      <link href={fontHref} rel="stylesheet" />
    ) : (
      <link
        href="https://fonts.googleapis.com/css2?family=M+PLUS+2:wght@400;500;700&family=M+PLUS+1+Code:wght@400;500&display=swap"
        rel="stylesheet"
      />
    )}
    <KaTeXLink />
    <title>{fullTitle}</title>
  </head>
  <body>
    <Header currentPath={Astro.url.pathname} />
    <main class="site-main"><slot /></main>
    <Footer />
    {!hideToc && <TableOfContents />}
    <CodeBlockEnhancer />
  </body>
</html>
