---
import options from "virtual:cosense-theme-default/options";
import site from "virtual:cosense-site-kit/site";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import TableOfContents from "./TableOfContents.astro";
import CodeBlockEnhancer from "./CodeBlockEnhancer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  /** Hide the floating right-side TOC (use on home / archive / tag pages). */
  hideToc?: boolean;
}

const { title, description, hideToc = false } = Astro.props;

const siteTitle =
  options.siteTitle ??
  site?.title ??
  (Astro.site ? new URL("/", Astro.site).hostname : title);
const fullTitle = siteTitle && siteTitle !== title ? `${title} | ${siteTitle}` : title;
const metaDescription = description ?? site?.description ?? "";
const lang = site?.lang ?? "ja";
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    {metaDescription && <meta name="description" content={metaDescription} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=M+PLUS+2:wght@400;500;700&family=M+PLUS+1+Code:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
  </head>
  <body>
    <Header currentPath={Astro.url.pathname} />
    <main class="site-main"><slot /></main>
    <Footer />
    {!hideToc && <TableOfContents />}
    <CodeBlockEnhancer />
  </body>
</html>
