---
import options from "virtual:cosense-theme-default/options";
import { loadStructure, loadTitleToSlug, navHref } from "../lib/structure";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
// Prefer the explicit siteTitle from theme options; fall back to the host of
// Astro.site (verbose) when not set.
const siteTitle =
  options.siteTitle ?? (Astro.site ? new URL("/", Astro.site).hostname : title);

// SiteStructure.nav wins over theme-options.nav when both are configured.
const structure = await loadStructure();
const navItems = structure.nav.length > 0 ? structure.nav : options.nav;
const titleToSlug = await loadTitleToSlug();
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href={import.meta.env.BASE_URL}>{siteTitle}</a>
      <nav class="site-nav">
        {navItems.map((item) => (
          <a href={navHref(item, titleToSlug)}>{item.label}</a>
        ))}
      </nav>
    </header>
    <main class="site-main">
      <slot />
    </main>
    <footer class="site-footer">
      <small>Built with cosense-site-kit</small>
    </footer>
  </body>
</html>
