---
import type { CollectionEntry } from "astro:content";
import Layout from "../components/Layout.astro";
import PageContent from "../components/PageContent.astro";
import { path } from "@cosense-site-kit/theme-utils";

// Profile template: a slim hero band over the body, no tag chips, and a
// "more pages" footer pointing back into the rest of the site. Suitable for
// About / Members / Bio pages.
//
// Opt in by tagging the Cosense page with `#template/profile`, or by mapping
// the title in `.site` site.yaml:
//
//   templates:
//     "About Me": profile

interface Props {
  entry: CollectionEntry<"pages">;
}

const { entry } = Astro.props;
const page = entry.data;
---
<Layout title={page.title} description={page.summary}>
  <article class="profile">
    <header class="profile-hero">
      <h1>{page.title}</h1>
      {page.summary && <p class="profile-summary">{page.summary}</p>}
    </header>

    <PageContent blocks={page.blocks} />

    <footer class="profile-source">
      <a href={page.sourceUrl} target="_blank" rel="noopener noreferrer">Source on Cosense ↗</a>
      {" · "}
      <a href={path("")}>← Back to home</a>
    </footer>
  </article>
</Layout>

<style>
  .profile-hero {
    text-align: center;
    padding: 2.5rem 1rem 2rem;
    border-bottom: 1px solid var(--color-divider);
    margin-bottom: 2.5rem;
  }
  .profile-hero h1 {
    font-size: 2.5rem;
    margin: 0 0 0.625rem;
    letter-spacing: -0.02em;
  }
  .profile-summary {
    color: var(--color-text-muted);
    font-size: 1.0625rem;
    max-width: 36rem;
    margin: 0 auto;
    line-height: 1.55;
  }
  .profile-source {
    margin-top: 3rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-divider);
    color: var(--color-text-muted);
    text-align: center;
    font-size: 0.8125rem;
  }
</style>
