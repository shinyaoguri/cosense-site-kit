---
import type { CollectionEntry } from "astro:content";
import { pagePaths } from "@cosense-site-kit/theme-utils";
import Collection from "./collection.astro";
import Page from "./page.astro";
import Profile from "./profile.astro";

// Theme's per-page template registry. Add a new template by importing the
// .astro file at the top and adding an entry below — the page-level
// `#template/<name>` tag and `.site` YAML `templates:` mapping look these up.
// Unknown names fall back to Page so a bad tag never 500s.
const TEMPLATES: Record<string, typeof Page> = {
  page: Page,
  profile: Profile,
  collection: Collection,
};

export async function getStaticPaths() {
  return pagePaths();
}

const { entry } = Astro.props as { entry: CollectionEntry<"pages"> };
const Template = TEMPLATES[entry.data.template] ?? Page;
---
<Template entry={entry} />
