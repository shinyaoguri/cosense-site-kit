---
import type { CollectionEntry } from "astro:content";
import Layout from "../components/Layout.astro";
import PageContent from "../components/PageContent.astro";
import Backlinks from "@cosense-site-kit/theme-utils/components/Backlinks.astro";
import { isPublicTag, path } from "@cosense-site-kit/theme-utils";

interface Props {
  entry: CollectionEntry<"pages">;
}

const { entry } = Astro.props;
const page = entry.data;
---
<Layout title={page.title} description={page.summary}>
  <article>
    <header class="page-header">
      <h1>{page.title}</h1>
      <div style="display: flex; flex-wrap: wrap; gap: 0.625rem; align-items: center;">
        {page.updatedAt && (
          <time class="updated" datetime={page.updatedAt}>
            {new Date(page.updatedAt).toISOString().slice(0, 10)}
          </time>
        )}
        {page.tags.some(isPublicTag) && (
          <div class="tags">
            {page.tags.filter(isPublicTag).map((tag) => (
              <a class="tag" href={path(`tags/${tag}`)}>#{tag}</a>
            ))}
          </div>
        )}
      </div>
    </header>

    <PageContent blocks={page.blocks} />

    <Backlinks backlinks={page.backlinks} />

    <footer class="source">
      <a href={page.sourceUrl} target="_blank" rel="noopener noreferrer">Source on Cosense ↗</a>
    </footer>
  </article>
</Layout>
