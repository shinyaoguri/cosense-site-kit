---
import { getCollection } from "astro:content";
import Layout from "../components/Layout.astro";
import { isPublicTag, path } from "@cosense-site-kit/theme-utils";

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  const tagMap = new Map<string, typeof pages>();
  for (const entry of pages) {
    for (const tag of entry.data.tags) {
      // Skip namespaced metadata tags (template/foo, slug/foo). They aren't
      // categories users browse, and slashes can't sit inside a [tag] segment.
      if (!isPublicTag(tag)) continue;
      const list = tagMap.get(tag) ?? [];
      list.push(entry);
      tagMap.set(tag, list);
    }
  }
  return Array.from(tagMap.entries()).map(([tag, entries]) => ({
    params: { tag },
    props: { entries },
  }));
}

const { tag } = Astro.params;
const { entries } = Astro.props as {
  entries: Awaited<ReturnType<typeof getCollection<"pages">>>;
};
---
<Layout title={`#${tag}`}>
  <h1>#{tag}</h1>
  <ul class="tag-page-list">
    {entries.map((entry) => (
      <li>
        <a href={path(entry.data.slug)}>{entry.data.title}</a>
        {entry.data.summary && <p class="summary">{entry.data.summary}</p>}
      </li>
    ))}
  </ul>
</Layout>
