---
import { getCollection } from "astro:content";
import options from "virtual:cosense-theme-default/options";
import site from "virtual:cosense-site-kit/site";
import Layout from "../components/Layout.astro";
import PageContent from "@cosense-site-kit/theme-utils/components/PageContent.astro";
import { loadStructure, loadTitleToSlug, path } from "@cosense-site-kit/theme-utils";

const structure = await loadStructure();
const titleToSlug = await loadTitleToSlug();

const allPages = await getCollection("pages");
allPages.sort((a, b) => (b.data.publishedAt ?? "").localeCompare(a.data.publishedAt ?? ""));

// 1. Home body: structure.home.page > options.homePage > none
const homeTitle = structure.home?.page ?? options.homePage;
const homeEntry = homeTitle
  ? allPages.find((e) => e.data.title === homeTitle || e.data.slug === homeTitle)
  : undefined;

const featured = structure.featured
  .map((title) => ({ title, slug: titleToSlug.get(title) }))
  .filter((f): f is { title: string; slug: string } => Boolean(f.slug));

const postTag = structure.posts?.tag;
const recent = postTag
  ? allPages.filter((e) => e.data.tags.includes(postTag)).slice(0, structure.posts?.limit ?? 10)
  : allPages.slice(0, 20);
const recentHeading = postTag ? "Recent posts" : "Recent pages";

const siteTitle = site?.title ?? Astro.site?.hostname ?? "Home";
const siteDescription = site?.description;
---
<Layout title={siteTitle} description={siteDescription} hideToc>
  {homeEntry ? (
    <article>
      <header class="page-header">
        <h1>{siteTitle}</h1>
        {siteDescription && <p class="summary" style="font-size: 1rem; margin-top: 0.25rem">{siteDescription}</p>}
      </header>
      <PageContent blocks={homeEntry.data.blocks} />
    </article>
  ) : (
    <header class="page-header">
      <h1>{siteTitle}</h1>
      {siteDescription && <p class="summary" style="font-size: 1rem">{siteDescription}</p>}
    </header>
  )}

  {featured.length > 0 && (
    <section class="featured">
      <h2>Featured</h2>
      <ul>
        {featured.map((f) => (
          <li><a href={path(f.slug)}>{f.title}</a></li>
        ))}
      </ul>
    </section>
  )}

  <section class="recent-pages">
    <h2>{recentHeading}</h2>
    <ul>
      {recent.map((entry) => (
        <li>
          <a href={path(entry.data.slug)}>{entry.data.title}</a>
          {entry.data.summary && <p class="summary">{entry.data.summary}</p>}
          {entry.data.publishedAt && (
            <time class="updated" datetime={entry.data.publishedAt}>
              {new Date(entry.data.publishedAt).toISOString().slice(0, 10)}
            </time>
          )}
        </li>
      ))}
    </ul>
  </section>
</Layout>
