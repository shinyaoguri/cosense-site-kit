---
import { getCollection } from "astro:content";
import type { GetStaticPaths, PaginateFunction } from "astro";
import {
  formatDate,
  hidesDates,
  isPublicTag,
  loadStructure,
  path,
} from "@cosense-site-kit/theme-utils";
import Layout from "../components/Layout.astro";
import EntryTags from "../components/EntryTags.astro";
import Pagination from "../components/Pagination.astro";
import { POSTS_PER_PAGE } from "../constants";

// /posts/[...page] — paginated list of pages tagged with the .site posts tag.
// Page 1 is /posts; later pages are /posts/2, /posts/3, … The route always
// emits at least page 1 (a stub when posts aren't configured) so /posts never
// 404s.
export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const structure = await loadStructure();
  const postTag = structure.posts?.tag;
  const all = await getCollection("pages");
  const posts = postTag
    ? all
        .filter((e) => e.data.tags.includes(postTag))
        .sort((a, b) => (b.data.publishedAt ?? "").localeCompare(a.data.publishedAt ?? ""))
    : [];

  if (posts.length === 0) {
    return [{ params: { page: undefined }, props: { entries: [], pageInfo: null, configured: Boolean(postTag) } }];
  }

  return (paginate as PaginateFunction)(posts, { pageSize: POSTS_PER_PAGE }).map((route) => ({
    params: route.params,
    props: {
      entries: route.props.page.data,
      pageInfo: {
        current: route.props.page.currentPage,
        last: route.props.page.lastPage,
        prevUrl: route.props.page.url.prev,
        nextUrl: route.props.page.url.next,
      },
      configured: true,
    },
  }));
};

type Entry = Awaited<ReturnType<typeof getCollection<"pages">>>[number];
const { entries, pageInfo, configured } = Astro.props as {
  entries: Entry[];
  pageInfo: { current: number; last: number; prevUrl?: string; nextUrl?: string } | null;
  configured: boolean;
};
---
<Layout title="Posts" hideToc>
  <header class="page-header">
    <h1>Posts</h1>
  </header>
  {configured ? (
    <section class="recent-pages">
      <ul>
        {entries.map((entry) => (
          <li>
            <a class="thumb" href={path(entry.data.slug)} aria-hidden="true" tabindex="-1">
              {entry.data.image
                ? <img src={entry.data.image} alt="" loading="lazy" decoding="async" />
                : <span class="thumb-placeholder">{Array.from(entry.data.title.trim())[0] ?? "·"}</span>}
            </a>
            <div class="entry-body">
              <a href={path(entry.data.slug)}>{entry.data.title}</a>
              {entry.data.summary && <p class="summary">{entry.data.summary}</p>}
              {((!hidesDates(entry.data.tags) && entry.data.publishedAt) || entry.data.tags.some(isPublicTag)) && (
                <div class="entry-meta">
                  {!hidesDates(entry.data.tags) && entry.data.publishedAt && (
                    <time class="updated" datetime={entry.data.publishedAt}>
                      {formatDate(entry.data.publishedAt)}
                    </time>
                  )}
                  <EntryTags tags={entry.data.tags} />
                </div>
              )}
            </div>
          </li>
        ))}
      </ul>
      {pageInfo && <Pagination {...pageInfo} />}
    </section>
  ) : (
    <p class="summary">Posts are not configured for this site.</p>
  )}
</Layout>
