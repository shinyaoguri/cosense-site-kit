---
import { getCollection } from "astro:content";
import options from "virtual:cosense-theme-portfolio/options";
import Layout from "../components/Layout.astro";
import PageContent from "../components/PageContent.astro";
import { loadStructure, loadTitleToSlug, path } from "@cosense-site-kit/theme-utils";

const structure = await loadStructure();
const titleToSlug = await loadTitleToSlug();
const all = await getCollection("pages");

const homeTarget = structure.home?.page ?? options.homePage;
const homeEntry = homeTarget
  ? all.find(
      (e) => e.data.title === homeTarget || e.data.slug === homeTarget,
    )
  : undefined;

// Mini-nav below the home intro. By default we surface About + CV; if those
// titles are not present in the project, we silently skip them. Operators
// can suppress this entirely by mapping nav explicitly via .site.
const MINI_NAV_TITLES = ["About", "CV"] as const;
const miniNav = MINI_NAV_TITLES
  .map((title) => ({ title, slug: titleToSlug.get(title) }))
  .filter((x): x is { title: string; slug: string } => Boolean(x.slug));
---
<Layout title="Home" hideToc>
  <section class="prose home-intro">
    {homeEntry ? (
      <PageContent blocks={homeEntry.data.blocks} />
    ) : (
      <p>Welcome.</p>
    )}

    {miniNav.length > 0 && (
      <nav class="home-mini-nav">
        {miniNav.map((item) => (
          <a href={path(item.slug)}>{item.title}</a>
        ))}
      </nav>
    )}
  </section>
</Layout>
