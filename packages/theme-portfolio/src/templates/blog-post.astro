---
import type { CollectionEntry } from "astro:content";
import Layout from "../components/Layout.astro";
import PageContent from "../components/PageContent.astro";
import Backlinks from "../components/Backlinks.astro";
import { isPublicTag, path } from "../lib/structure";

interface Props {
  entry: CollectionEntry<"pages">;
}

const { entry } = Astro.props;
const page = entry.data;
const dateIso = page.createdAt ?? page.updatedAt;
const dateStr = dateIso ? new Date(dateIso).toISOString().slice(0, 10) : null;
const visibleTags = page.tags.filter(isPublicTag);
---
<Layout title={page.title} description={page.summary}>
  <article class="prose">
    <header>
      <h1 class="blog-post-title">{page.title}</h1>
      <div class="blog-post-meta">
        {dateStr && <time datetime={dateIso}>{dateStr}</time>}
        {visibleTags.length > 0 && (
          <span>
            {visibleTags.map((tag) => (
              <a class="tag" href={path(`tags/${tag}`)}>#{tag}</a>
            ))}
          </span>
        )}
      </div>
    </header>

    <PageContent blocks={page.blocks} />

    <Backlinks backlinks={page.backlinks} />

    <p class="source-link">
      <a href={page.sourceUrl} target="_blank" rel="noopener noreferrer">
        Source on Cosense ↗
      </a>
    </p>
  </article>
</Layout>
