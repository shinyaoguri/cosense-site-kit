---
// Dispatcher for /[...slug]. Picks a template per page from:
//   1. blogTag presence → blog-post (overrides any explicit template)
//   2. entry.data.template → TEMPLATES lookup
//   3. fallback → page
import { getCollection, type CollectionEntry } from "astro:content";
import options from "virtual:cosense-theme-portfolio/options";
import Page from "./page.astro";
import Profile from "./profile.astro";
import Cv from "./cv.astro";
import BlogPost from "./blog-post.astro";

const TEMPLATES: Record<string, typeof Page> = {
  page: Page,
  profile: Profile,
  cv: Cv,
  "blog-post": BlogPost,
};

export async function getStaticPaths() {
  const pages = await getCollection("pages");
  return pages.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"pages"> };
const data = entry.data as { template: string; tags: string[] };

// Any page tagged with the blogTag is rendered with blog-post (regardless of
// what `templates:` or `#template/<name>` says). This lets Cosense authors
// publish blog posts by tagging `#publish #blog` with no extra ceremony.
const isBlogPost = data.tags.includes(options.blogTag);
const Template = isBlogPost
  ? BlogPost
  : (TEMPLATES[data.template] ?? Page);
---
<Template entry={entry} />
