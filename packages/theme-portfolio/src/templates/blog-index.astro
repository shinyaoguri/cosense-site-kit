---
import { getCollection } from "astro:content";
import options from "virtual:cosense-theme-portfolio/options";
import Layout from "../components/Layout.astro";
import BlogCard from "../components/BlogCard.astro";
import { postSummary } from "../lib/blog";
import { loadStructure } from "@cosense-site-kit/theme-utils";

// Posts are surfaced by tag membership. `posts.tag` from .site wins; if
// absent, fall back to the theme's blogTag option (default "blog").
const structure = await loadStructure();
const blogTag = structure.posts?.tag ?? options.blogTag;
const limit = structure.posts?.limit;

const all = await getCollection("pages");
let posts = all
  .filter((e) => e.data.tags.includes(blogTag))
  .sort((a, b) => {
    const ad = a.data.createdAt ?? a.data.updatedAt ?? "";
    const bd = b.data.createdAt ?? b.data.updatedAt ?? "";
    return bd.localeCompare(ad);
  });
if (limit && limit > 0) posts = posts.slice(0, limit);

const summaries = posts.map((e) => postSummary(e));
---
<Layout title="Blog" description="ブログ記事一覧" hideToc>
  <article>
    {summaries.length === 0 ? (
      <p class="blog-empty">記事がありません</p>
    ) : (
      <div class="blog-grid">
        {summaries.map((post) => <BlogCard post={post} />)}
      </div>
    )}
  </article>
</Layout>
