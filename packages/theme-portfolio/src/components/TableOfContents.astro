---
// Notion-style hover TOC. The script scans h2/h3 inside .prose, populates
// indicator bars + a hover panel, and runs an IntersectionObserver to mark
// the active heading. Ported from shinyaoguri.com.
---
<nav class="toc" aria-label="目次">
  <div class="toc-indicator"></div>
  <div class="toc-panel">
    <ul class="toc-list"></ul>
  </div>
</nav>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const toc = document.querySelector(".toc");
    const indicator = document.querySelector(".toc-indicator");
    const list = document.querySelector(".toc-list");
    if (!toc || !indicator || !list) return;

    const headings = document.querySelectorAll<HTMLHeadingElement>(
      ".prose h2, .prose h3",
    );
    if (headings.length === 0) {
      toc.remove();
      return;
    }

    headings.forEach((heading, index) => {
      if (!heading.id) heading.id = `heading-${index}`;
      const isH3 = heading.tagName === "H3";

      const bar = document.createElement("div");
      bar.className = `toc-bar ${isH3 ? "toc-bar-h3" : "toc-bar-h2"}`;
      bar.dataset.target = heading.id;
      indicator.appendChild(bar);

      const li = document.createElement("li");
      li.className = `toc-item ${isH3 ? "toc-item-h3" : ""}`;
      const a = document.createElement("a");
      a.href = `#${heading.id}`;
      a.textContent = heading.textContent ?? "";
      a.className = "toc-link";
      a.dataset.target = heading.id;
      a.addEventListener("click", (e) => {
        e.preventDefault();
        heading.scrollIntoView({ behavior: "smooth", block: "start" });
        history.pushState(null, "", `#${heading.id}`);
      });
      li.appendChild(a);
      list.appendChild(li);
    });

    let currentActiveId: string | null = null;
    const setActive = (id: string) => {
      if (currentActiveId) {
        indicator
          .querySelector(`[data-target="${currentActiveId}"]`)
          ?.classList.remove("is-active");
        list
          .querySelector(`[data-target="${currentActiveId}"]`)
          ?.classList.remove("is-active");
      }
      indicator
        .querySelector(`[data-target="${id}"]`)
        ?.classList.add("is-active");
      list
        .querySelector(`[data-target="${id}"]`)
        ?.classList.add("is-active");
      currentActiveId = id;
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) setActive(entry.target.id);
        }
      },
      { rootMargin: "-80px 0px -70% 0px", threshold: 0 },
    );
    for (const h of headings) observer.observe(h);
  });
</script>
