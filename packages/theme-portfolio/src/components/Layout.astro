---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import TableOfContents from "./TableOfContents.astro";
import CodeBlockEnhancer from "./CodeBlockEnhancer.astro";
import options from "virtual:cosense-theme-portfolio/options";
import site from "virtual:cosense-site-kit/site";
import "../styles/global.css";
import "../styles/toc.css";
import "../styles/blog.css";
import "../styles/cv.css";

interface Props {
  title: string;
  description?: string;
  /** Hide the floating TOC (e.g. on home / index pages). Default: false. */
  hideToc?: boolean;
}

const { title, description, hideToc = false } = Astro.props;

const siteTitle =
  options.siteTitle ??
  site?.title ??
  (Astro.site ? new URL("/", Astro.site).hostname : title);
const titleSuffix = siteTitle && siteTitle !== title ? ` | ${siteTitle}` : "";
const fullTitle = `${title}${titleSuffix}`;
const metaDescription = description ?? options.siteDescription ?? site?.description ?? "";
const lang = site?.lang ?? "ja";
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {metaDescription && <meta name="description" content={metaDescription} />}
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=M+PLUS+1:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <title>{fullTitle}</title>
  </head>
  <body>
    <Header currentPath={Astro.url.pathname} />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
    {!hideToc && <TableOfContents />}
    <CodeBlockEnhancer />
  </body>
</html>
