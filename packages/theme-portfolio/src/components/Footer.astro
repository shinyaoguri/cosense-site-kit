---
import options from "virtual:cosense-theme-portfolio/options";
import site from "virtual:cosense-site-kit/site";

const currentYear = new Date().getFullYear();
const holder =
  options.copyrightHolder ?? options.siteTitle ?? site?.title ?? "";
---
<footer class="site-footer">
  <div class="site-footer-inner">
    <p class="site-footer-copy">&copy; {currentYear} {holder}</p>
  </div>
</footer>
