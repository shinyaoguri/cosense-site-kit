---
import { loadStructure, loadTitleToSlug, navHref } from "../lib/structure";
import options from "virtual:cosense-theme-portfolio/options";
import site from "virtual:cosense-site-kit/site";

interface Props {
  /** Pathname of the current page, used to mark the active nav item. */
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const siteTitle =
  options.siteTitle ??
  site?.title ??
  (Astro.site ? new URL("/", Astro.site).hostname : "Site");

const structure = await loadStructure();
const navItems = structure.nav.length > 0 ? structure.nav : options.nav;
const titleToSlug = await loadTitleToSlug();

const isActive = (href: string): boolean => {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(`${href}/`);
};
---
<header class="site-header">
  <nav class="site-nav-wrap">
    <div class="site-nav-row">
      <a class="site-title" href={import.meta.env.BASE_URL}>{siteTitle}</a>
      <ul class="site-nav">
        {navItems.map((item) => {
          const href = navHref(item, titleToSlug);
          return (
            <li>
              <a href={href} class:list={["site-nav-link", { "is-active": isActive(href) }]}>
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  </nav>
</header>
