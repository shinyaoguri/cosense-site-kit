{
  "name": "@cosense-site-kit/theme-lab",
  "version": "0.0.0",
  "description": "University research lab theme for cosense-site-kit (members, research, publications, news)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": "./src/components/*",
    "./templates/*": "./src/templates/*",
    "./styles/*": "./src/styles/*"
  },
  "files": ["dist", "src/components", "src/templates", "src/styles", "src/virtual"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "astro": "^5.0.0"
  },
  "dependencies": {
    "@cosense-site-kit/core": "*",
    "@cosense-site-kit/theme-utils": "*",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "astro": "^5.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
