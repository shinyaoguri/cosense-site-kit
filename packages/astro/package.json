{
  "name": "@cosense-site-kit/astro",
  "version": "0.1.4",
  "description": "Astro Content Loader and Integration for cosense-site-kit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shinyaoguri/cosense-site-kit.git",
    "directory": "packages/astro"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "astro": "^5.0.0 || ^6.0.0"
  },
  "dependencies": {
    "@cosense-site-kit/core": "^0.3.1"
  },
  "devDependencies": {
    "astro": "^6.4.7",
    "tsup": "^8.3.5",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
