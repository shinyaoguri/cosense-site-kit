{
  "name": "@cosense-site-kit/theme-utils",
  "version": "0.0.0",
  "description": "Shared runtime helpers for cosense-site-kit themes",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": "./src/components/*"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "astro": "^5.0.0 || ^6.0.0"
  },
  "dependencies": {
    "@cosense-site-kit/core": "*",
    "katex": "^0.16.11"
  },
  "devDependencies": {
    "astro": "^6.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
