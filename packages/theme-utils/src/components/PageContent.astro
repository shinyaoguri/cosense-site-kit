---
import { Code } from "astro:components";
import type { CosenseBlock } from "@cosense-site-kit/core";
import Inline from "./Inline.astro";

// Languages Shiki can highlight at build time. `code:<file>` blocks whose
// inferred language isn't here fall back to plaintext so the build never fails
// on an exotic extension. Light/dark are emitted as one block; a theme picks
// the active set via CSS keyed on its skin (see theme-default global.css).
const SHIKI_LANGS = new Set([
  "ts", "tsx", "js", "jsx", "json", "jsonc", "python", "ruby", "go", "rust",
  "bash", "shell", "sh", "markdown", "md", "yaml", "yml", "html", "css", "scss",
  "less", "sql", "toml", "ini", "diff", "xml", "c", "cpp", "csharp", "java",
  "kotlin", "swift", "php", "vue", "svelte", "astro", "dockerfile", "graphql",
  "plaintext", "text",
]);
function safeLang(lang: string | undefined): string {
  const l = lang?.toLowerCase();
  return l && SHIKI_LANGS.has(l) ? l : "plaintext";
}

interface Props {
  blocks: CosenseBlock[];
  /**
   * Extra `code:<filename>` blocks whose body should be hidden from prose.
   * `site.yaml` is always hidden (the framework consumes it as site config);
   * a theme that uses YAML data blocks like `cv.yaml` passes them here.
   */
  hideFilenames?: string[];
  /** Wrapper class on the root <div>. Default: "page-content". */
  class?: string;
}

const { blocks, hideFilenames = [], class: wrapperClass = "page-content" } =
  Astro.props;
const hidden = new Set(["site.yaml", ...hideFilenames]);
const visible = blocks.filter(
  (b) => !(b.type === "code" && b.filename && hidden.has(b.filename)),
);
---
<div class={wrapperClass}>
  {visible.map((block) => {
    switch (block.type) {
      case "paragraph":
        return <p><Inline nodes={block.children} /></p>;
      case "heading":
        if (block.depth === 1) return <h2><Inline nodes={block.children} /></h2>;
        if (block.depth === 2) return <h3><Inline nodes={block.children} /></h3>;
        return <h4><Inline nodes={block.children} /></h4>;
      case "list":
        return (
          <ul style={`margin-left: ${(block.depth - 1) * 1.5}em`}>
            <li><Inline nodes={block.children} /></li>
          </ul>
        );
      case "code": {
        // Build-time syntax highlighting via Astro's bundled Shiki. Dual theme
        // (light/dark) so a theme can switch by skin in CSS. <Code> sets
        // `data-language` on the <pre> itself, which the theme's language label
        // reads.
        const lang = safeLang(block.lang);
        return (
          <Code
            code={block.value}
            lang={lang}
            themes={{ light: "github-light", dark: "github-dark" }}
          />
        );
      }
      case "image":
        return <img src={block.url} alt={block.alt ?? ""} loading="lazy" />;
      case "embed":
        return <a href={block.url} rel="noopener noreferrer" target="_blank">{block.url}</a>;
      case "table":
        return (
          <table>
            {block.filename && <caption>{block.filename}</caption>}
            <tbody>
              {block.rows.map((row) => (
                <tr>{row.map((cell) => <td>{cell}</td>)}</tr>
              ))}
            </tbody>
          </table>
        );
      case "raw":
        return <pre>{block.value}</pre>;
      default:
        return null;
    }
  })}
</div>
