---
import { Code } from "astro:components";
import type { CosenseBlock, InlineNode } from "@cosense-site-kit/core";
import { type EmbedProvider, resolveEmbed } from "../embeds";
import { buildListTree } from "../lists";
import Inline from "./Inline.astro";
import ListTree from "./ListTree.astro";

// Languages Shiki can highlight at build time. `code:<file>` blocks whose
// inferred language isn't here fall back to plaintext so the build never fails
// on an exotic extension. Light/dark are emitted as one block; a theme picks
// the active set via CSS keyed on its skin (see theme-default global.css).
const SHIKI_LANGS = new Set([
  "ts", "tsx", "js", "jsx", "json", "jsonc", "python", "ruby", "go", "rust",
  "bash", "shell", "sh", "markdown", "md", "yaml", "yml", "html", "css", "scss",
  "less", "sql", "toml", "ini", "diff", "xml", "c", "cpp", "csharp", "java",
  "kotlin", "swift", "php", "vue", "svelte", "astro", "dockerfile", "graphql",
  "plaintext", "text",
]);
function safeLang(lang: string | undefined): string {
  const l = lang?.toLowerCase();
  return l && SHIKI_LANGS.has(l) ? l : "plaintext";
}

interface Props {
  blocks: CosenseBlock[];
  /**
   * Extra `code:<filename>` blocks whose body should be hidden from prose.
   * `site.yaml` is always hidden (the framework consumes it as site config);
   * a theme that uses YAML data blocks like `cv.yaml` passes them here.
   */
  hideFilenames?: string[];
  /** Wrapper class on the root <div>. Default: "page-content". */
  class?: string;
  /**
   * Extra embed providers, tried before the built-ins (YouTube/Vimeo/Spotify).
   * The extension point for themes to support more services without a core
   * change — a standalone URL with no matching provider renders as a link.
   */
  embedProviders?: EmbedProvider[];
}

const { blocks, hideFilenames = [], class: wrapperClass = "page-content", embedProviders } =
  Astro.props;
const hidden = new Set(["site.yaml", ...hideFilenames]);
const visible = blocks.filter(
  (b) => !(b.type === "code" && b.filename && hidden.has(b.filename)),
);

// The parser emits one block per line, so consecutive list items / quote lines
// arrive as separate blocks. Fold each run together: list runs become one
// nested <ul>/<ol> (via buildListTree), quote runs become one <blockquote>.
type ListBlock = Extract<CosenseBlock, { type: "list" }>;
type Group =
  | { kind: "list"; items: ListBlock[] }
  | { kind: "quote"; rows: InlineNode[][] }
  | { kind: "block"; block: CosenseBlock };
const groups: Group[] = [];
for (const block of visible) {
  const last = groups[groups.length - 1];
  if (block.type === "list") {
    if (last?.kind === "list") last.items.push(block);
    else groups.push({ kind: "list", items: [block] });
  } else if (block.type === "quote") {
    if (last?.kind === "quote") last.rows.push(block.children);
    else groups.push({ kind: "quote", rows: [block.children] });
  } else {
    groups.push({ kind: "block", block });
  }
}
---
<div class={wrapperClass}>
  {groups.map((group) => {
    if (group.kind === "list") {
      return <ListTree items={buildListTree(group.items)} />;
    }
    if (group.kind === "quote") {
      return (
        <blockquote>
          {group.rows.map((row) => <p><Inline nodes={row} /></p>)}
        </blockquote>
      );
    }
    const block = group.block;
    switch (block.type) {
      case "paragraph":
        return <p><Inline nodes={block.children} /></p>;
      case "heading":
        if (block.depth === 1) return <h2><Inline nodes={block.children} /></h2>;
        if (block.depth === 2) return <h3><Inline nodes={block.children} /></h3>;
        return <h4><Inline nodes={block.children} /></h4>;
      case "code": {
        // Build-time syntax highlighting via Astro's bundled Shiki. Dual theme
        // (light/dark) so a theme can switch by skin in CSS. <Code> sets
        // `data-language` on the <pre> itself, which the theme's language label
        // reads.
        const lang = safeLang(block.lang);
        return (
          <Code
            code={block.value}
            lang={lang}
            themes={{ light: "github-light", dark: "github-dark" }}
          />
        );
      }
      case "image":
        // Content images are arbitrary remote URLs (Gyazo, Scrapbox uploads),
        // so we serve them directly with lazy loading + async decode rather than
        // running them through astro:assets — a build-time fetch of every image
        // would fail the (unattended, cron) build if one is unreachable. Themes
        // that host images reliably can opt into <Image> (see docs/THEMES.md).
        return <img src={block.url} alt={block.alt ?? ""} loading="lazy" decoding="async" />;
      case "embed": {
        const embed = resolveEmbed(block.url, embedProviders);
        if (embed) {
          return (
            <div
              class={`embed embed-${embed.provider}`}
              style={embed.height ? undefined : `--embed-ratio: ${embed.aspectRatio ?? "16 / 9"}`}
            >
              <iframe
                src={embed.src}
                title={embed.title}
                loading="lazy"
                height={embed.height}
                referrerpolicy="strict-origin-when-cross-origin"
                allow={embed.allow}
                allowfullscreen
              />
            </div>
          );
        }
        // No provider matched (or unparsable URL): plain link.
        return <a href={block.url} rel="noopener noreferrer" target="_blank">{block.url}</a>;
      }
      case "table":
        return (
          <table>
            {block.filename && <caption>{block.filename}</caption>}
            <tbody>
              {block.rows.map((row) => (
                <tr>{row.map((cell) => <td><Inline nodes={cell} /></td>)}</tr>
              ))}
            </tbody>
          </table>
        );
      case "raw":
        return <pre>{block.value}</pre>;
      default:
        return null;
    }
  })}
</div>
