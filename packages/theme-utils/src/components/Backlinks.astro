---
import { loadTitleToSlug, path } from "../structure";

interface Props {
  backlinks: string[];
}

const { backlinks } = Astro.props;
const titleToSlug = await loadTitleToSlug();
const resolved = backlinks
  .map((title) => ({ title, slug: titleToSlug.get(title) }))
  .filter((b): b is { title: string; slug: string } => Boolean(b.slug));
---
{resolved.length > 0 && (
  <aside class="backlinks" data-pagefind-ignore>
    <h4>Backlinks</h4>
    <ul>
      {resolved.map((b) => (
        <li><a href={path(b.slug)}>{b.title}</a></li>
      ))}
    </ul>
  </aside>
)}
