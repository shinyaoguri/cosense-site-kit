---
import type { CollectionEntry } from "astro:content";
import Layout from "../components/Layout.astro";
import PageContent from "../components/PageContent.astro";
import { path } from "@cosense-site-kit/theme-utils";

interface Props { entry: CollectionEntry<"pages"> }
const { entry } = Astro.props;
const page = entry.data;
---
<Layout title={page.title} description={page.summary}>
  <article class="site-section">
    <div class="prose">
      <p class="page-meta">
        <span class="page-meta-eyebrow">Service</span>
      </p>
      <h1>{page.title}</h1>
      <PageContent blocks={page.blocks} />
      <p style="margin-top: 2.5rem">
        <a href={path("services")}>← Services へ戻る</a>
      </p>
      <p class="source-link">
        <a href={page.sourceUrl} target="_blank" rel="noopener noreferrer">
          Source on Cosense ↗
        </a>
      </p>
    </div>
  </article>
</Layout>
