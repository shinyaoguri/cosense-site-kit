---
import { getCollection } from "astro:content";
import options from "virtual:cosense-theme-organisation/options";
import Layout from "../components/Layout.astro";
import { path } from "@cosense-site-kit/theme-utils";
import { cardSummary } from "../lib/cards";

const tag = options.caseTag;
const all = await getCollection("pages");
const cases = all
  .filter((e) => e.data.tags.includes(tag))
  .map(cardSummary);
---
<Layout title="Cases" description="導入事例・実績">
  <article class="site-section wide">
    <h1 class="section-heading">Cases</h1>
    {cases.length === 0 ? (
      <p style="color: var(--color-text-muted)">
        事例は <code>#{tag}</code> タグ付きのページとして公開してください。
      </p>
    ) : (
      <ul class="card-grid">
        {cases.map((c) => (
          <li>
            <a class="card" href={path(c.slug)}>
              <span class="card-eyebrow">Case study</span>
              <h3>{c.title}</h3>
              {c.description && <p>{c.description}</p>}
            </a>
          </li>
        ))}
      </ul>
    )}
  </article>
</Layout>
