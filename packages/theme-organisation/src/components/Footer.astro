---
import options from "virtual:cosense-theme-organisation/options";
import site from "virtual:cosense-site-kit/site";
import { loadTitleToSlug, navHref } from "@cosense-site-kit/theme-utils";

const year = new Date().getFullYear();
const holder = options.copyrightHolder ?? options.siteTitle ?? site?.title ?? "";
const columns = options.footer ?? [];
const titleToSlug = await loadTitleToSlug();
---
<footer class="site-footer">
  {columns.length > 0 && (
    <div class="site-footer-inner">
      {columns.map((col) => (
        <div class="footer-col">
          <h5>{col.heading}</h5>
          <ul>
            {col.items.map((item) => (
              <li><a href={navHref(item, titleToSlug)}>{item.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  )}
  <div class="site-footer-copy">
    &copy; {year} {holder}
  </div>
</footer>
