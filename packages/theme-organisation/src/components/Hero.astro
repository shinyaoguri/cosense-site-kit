---
import options from "virtual:cosense-theme-organisation/options";
import { path } from "@cosense-site-kit/theme-utils";

const headline = options.heroHeadline ?? options.siteTitle ?? "Welcome";
const subhead = options.heroSubhead;
const ctaLabel = options.heroCtaLabel;
const ctaHref = options.heroCtaHref;

// Site-relative CTA hrefs get the configured base prefix; absolute URLs pass.
const resolvedCta =
  ctaHref && ctaHref.startsWith("/")
    ? `${import.meta.env.BASE_URL.replace(/\/$/, "")}${ctaHref}`
    : ctaHref;
---
<section class="hero">
  <div class="hero-inner">
    <h1>{headline}</h1>
    {subhead && <p>{subhead}</p>}
    {ctaLabel && resolvedCta && (
      <a class="hero-cta" href={resolvedCta}>{ctaLabel}</a>
    )}
  </div>
</section>
