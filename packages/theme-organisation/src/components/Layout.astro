---
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import options from "virtual:cosense-theme-organisation/options";
import site from "virtual:cosense-site-kit/site";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const siteTitle = options.siteTitle ?? site?.title ?? title;
const fullTitle = siteTitle && siteTitle !== title ? `${title} | ${siteTitle}` : title;
const metaDescription =
  description ?? options.siteDescription ?? site?.description ?? "";
const lang = site?.lang ?? "ja";
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {metaDescription && <meta name="description" content={metaDescription} />}
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css"
      integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+"
      crossorigin="anonymous"
    />
    <title>{fullTitle}</title>
  </head>
  <body>
    <Header currentPath={Astro.url.pathname} />
    <main class="site-main"><slot /></main>
    <Footer />
  </body>
</html>
